# -*- coding: utf-8 -*-
from flask import Blueprint, jsonify, request
from db_config import get_db_connection
from datetime import datetime, timedelta
import random
import smtplib
import os
import json
from email.mime.text import MIMEText

auth_bp = Blueprint('auth', __name__)

# ============================================
# 🔐 CONFIGURACIÓN DESDE VARIABLES DE ENTORNO
# ============================================

ADMIN_EMAILS = os.environ.get('ADMIN_EMAILS', 'locasio918@gmail.com').split(',')
REMITENTE_EMAIL = os.environ.get('EMAIL_USER', 'locasio918@gmail.com')
REMITENTE_PASSWORD = os.environ.get('EMAIL_PASSWORD', '')

def generar_codigo_cliente():
    """Generar código único de cliente (MOP + 6 dígitos)"""
    return 'MOP' + str(random.randint(100000, 999999))

# ============================================
# 📧 ENVIAR CÓDIGO POR CORREO
# ============================================
@auth_bp.route('/api/enviar-codigo-email', methods=['POST'])
def enviar_codigo_email():
    try:
        datos = request.json
        email_destino = datos.get('email')
        
        if not email_destino:
            return jsonify({'error': 'Falta el correo destino'}), 400
        
        if not REMITENTE_PASSWORD:
            print("️ ERROR: EMAIL_PASSWORD no configurado en variables de entorno")
            return jsonify({'error': 'Configuración de correo no disponible'}), 500
        
        codigo = str(random.randint(100000, 999999))
        expira = datetime.now() + timedelta(minutes=5)
        
        conn = get_db_connection()
        cursor = conn.cursor()
        
        cursor.execute("""
            INSERT INTO codigos_verificacion (email, codigo, expira) 
            VALUES (%s, %s, %s)
            ON DUPLICATE KEY UPDATE codigo = VALUES(codigo), expira = VALUES(expira)
        """, (email_destino, codigo, expira))
        conn.commit()
        cursor.close()
        conn.close()
        
        # Crear el mensaje del correo
        mensaje_html = f"""
        <html>
            <body style="font-family: Arial, sans-serif; text-align: center; padding: 30px; background-color: #f4f4f4;">
                <div style="background-color: white; padding: 20px; border-radius: 10px; max-width: 400px; margin: auto; box-shadow: 0 4px 8px rgba(0,0,0,0.1);">
                    <h2 style="color: #D4AF37; margin-bottom: 5px;">iGrafic360</h2>
                    <p style="color: #555; font-size: 16px;">Tu código de verificación es:</p>
                    <h1 style="font-size: 40px; letter-spacing: 5px; color: #111; background: #f9f9f9; padding: 10px; border-radius: 5px;">{codigo}</h1>
                    <p style="color: #999; font-size: 12px; margin-top: 20px;">Este código expira en 5 minutos. No lo compartas con nadie.</p>
                </div>
            </body>
        </html>
        """
        msg = MIMEText(mensaje_html, 'html')
        msg['Subject'] = 'Código de Verificación - iGrafic360 '
        msg['From'] = f"iGrafic360 <{REMITENTE_EMAIL}>"
        msg['To'] = email_destino
        
        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(REMITENTE_EMAIL, REMITENTE_PASSWORD)
        server.sendmail(REMITENTE_EMAIL, email_destino, msg.as_string())
        server.quit()
        
        return jsonify({'success': True})
    except Exception as e:
        print(f"Error enviando correo: {e}")
        return jsonify({'error': str(e)}), 500

# ============================================
# ✅ VERIFICAR CÓDIGO
# ============================================
@auth_bp.route('/api/verificar-codigo-email', methods=['POST'])
def verificar_codigo_email():
    try:
        datos = request.json
        email = datos.get('email')
        codigo = datos.get('codigo')
        
        if not email or not codigo:
            return jsonify({'error': 'Faltan datos'}), 400
        
        conn = get_db_connection()
        cursor = conn.cursor(dictionary=True)
        
        cursor.execute("""
            SELECT codigo, expira FROM codigos_verificacion WHERE email = %s
        """, (email,))
        resultado = cursor.fetchone()
        
        if not resultado:
            cursor.close()
            conn.close()
            return jsonify({'error': 'No hay un código pendiente para este correo.'}), 400
        
        if resultado['expira'] < datetime.now():
            # Eliminar código expirado
            cursor.execute("DELETE FROM codigos_verificacion WHERE email = %s", (email,))
            conn.commit()
            cursor.close()
            conn.close()
            return jsonify({'error': 'El código ha expirado. Pide uno nuevo.'}), 400
        
        if resultado['codigo'] == str(codigo):
            # Eliminar código usado
            cursor.execute("DELETE FROM codigos_verificacion WHERE email = %s", (email,))
            conn.commit()
            cursor.close()
            conn.close()
            return jsonify({'success': True})
        
        cursor.close()
        conn.close()
        return jsonify({'error': 'Código incorrecto.'}), 400
        
    except Exception as e:
        print(f"Error verificando código: {e}")
        return jsonify({'error': str(e)}), 500

# ============================================
# 📝 REGISTRO
# ============================================
@auth_bp.route('/api/auth/registro', methods=['POST'])
def api_registro():
    try:
        datos = request.json
        email = datos.get('email', '')
        nombre = datos.get('nombre', 'Cliente')
        telefono = datos.get('telefono', '')
        
        if email in ADMIN_EMAILS:
            rol = 'admin'
        else:
            rol = datos.get('rol', 'cliente')
        
        print(f"--- REGISTRANDO --- Nombre: {nombre} | Email: {email} | Tel: {telefono} | Rol: {rol}")
        
        # Generar UID simulado o usar el que viene de Firebase
        uid = datos.get('uid')
        if not uid:
            # Si no viene uid, generar uno (para compatibilidad con Firebase)
            import hashlib
            uid = hashlib.md5(email.encode()).hexdigest()[:28]
        
        conn = get_db_connection()
        cursor = conn.cursor(dictionary=True)
        
        # Verificar si ya existe
        cursor.execute("SELECT * FROM clientes WHERE email = %s", (email,))
        cliente_existente = cursor.fetchone()
        
        if not cliente_existente:
            codigo_cliente = generar_codigo_cliente()
            paquetes_json = json.dumps([])
            
            cursor.execute("""
                INSERT INTO clientes (uid, nombre, email, telefono, codigo_cliente, rol, fecha_registro, paquetes)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
            """, (uid, nombre, email, telefono, codigo_cliente, rol, datetime.now(), paquetes_json))
            conn.commit()
            print(f" Cliente creado con código: {codigo_cliente}")
            
            cliente_actualizado = {
                'nombre': nombre,
                'email': email,
                'telefono': telefono,
                'codigo_cliente': codigo_cliente,
                'rol': rol
            }
        else:
            # Actualizar datos si es necesario
            update_fields = []
            update_values = []
            
            if nombre != "Cliente" and cliente_existente['nombre'] != nombre:
                update_fields.append("nombre = %s")
                update_values.append(nombre)
            if telefono and cliente_existente['telefono'] != telefono:
                update_fields.append("telefono = %s")
                update_values.append(telefono)
            if cliente_existente['rol'] != rol:
                update_fields.append("rol = %s")
                update_values.append(rol)
            if not cliente_existente.get('codigo_cliente'):
                codigo_cliente = generar_codigo_cliente()
                update_fields.append("codigo_cliente = %s")
                update_values.append(codigo_cliente)
            
            if update_fields:
                update_values.append(email)
                cursor.execute(f"""
                    UPDATE clientes SET {', '.join(update_fields)} WHERE email = %s
                """, update_values)
                conn.commit()
            
            # Obtener datos actualizados
            cursor.execute("SELECT * FROM clientes WHERE email = %s", (email,))
            cliente_actualizado = cursor.fetchone()
        
        cursor.close()
        conn.close()
        
        return jsonify({
            'mensaje': 'Usuario procesado con exito',
            'uid': uid,
            'nombre_guardado': cliente_actualizado['nombre'],
            'rol': cliente_actualizado['rol'],
            'codigo_cliente': cliente_actualizado.get('codigo_cliente', 'PENDIENTE')
        }), 201
        
    except Exception as e:
        print(f"Error Registro: {e}")
        return jsonify({'error': str(e)}), 400

# ============================================
# 🔐 LOGIN
# ============================================
@auth_bp.route('/api/auth/login', methods=['POST'])
def api_login():
    try:
        datos = request.json
        uid = datos.get('uid')
        
        if not uid:
            return jsonify({'error': 'uid requerido'}), 400
        
        conn = get_db_connection()
        cursor = conn.cursor(dictionary=True)
        
        cursor.execute("SELECT * FROM clientes WHERE uid = %s", (uid,))
        cliente = cursor.fetchone()
        
        # Obtener email del usuario (esto vendría de Firebase Auth)
        # Por ahora, buscamos por uid o lo creamos
        email_usuario = datos.get('email', '')
        
        if not cliente:
            print("Cliente no existía en MySQL, creándolo...")
            rol_asignado = 'admin' if email_usuario in ADMIN_EMAILS else 'cliente'
            nombre_asignado = datos.get('nombre', email_usuario.split('@')[0] if email_usuario else 'Cliente')
            codigo_cliente = generar_codigo_cliente()
            paquetes_json = json.dumps([])
            
            cursor.execute("""
                INSERT INTO clientes (uid, nombre, email, telefono, codigo_cliente, rol, fecha_registro, paquetes)
                VALUES (%s, %s, %s, %s, %s, %s, %s, %s)
            """, (uid, nombre_asignado, email_usuario, '', codigo_cliente, rol_asignado, datetime.now(), paquetes_json))
            conn.commit()
            
            cliente_data = {
                'nombre': nombre_asignado,
                'email': email_usuario,
                'telefono': '',
                'codigo_cliente': codigo_cliente,
                'rol': rol_asignado,
                'paquetes': []
            }
        else:
            cliente_data = {
                'nombre': cliente['nombre'],
                'email': cliente['email'],
                'telefono': cliente['telefono'] or '',
                'codigo_cliente': cliente['codigo_cliente'],
                'rol': cliente['rol'],
                'paquetes': json.loads(cliente['paquetes']) if cliente['paquetes'] else []
            }
            
            # Asignar código si no tiene
            if not cliente_data['codigo_cliente']:
                nuevo_codigo = generar_codigo_cliente()
                cursor.execute("UPDATE clientes SET codigo_cliente = %s WHERE uid = %s", (nuevo_codigo, uid))
                conn.commit()
                cliente_data['codigo_cliente'] = nuevo_codigo
                print(f" Código asignado a cliente existente: {nuevo_codigo}")
            
            # Forzar rol admin si el email está en ADMIN_EMAILS
            if email_usuario in ADMIN_EMAILS and cliente_data['rol'] != 'admin':
                cursor.execute("UPDATE clientes SET rol = 'admin' WHERE uid = %s", (uid,))
                conn.commit()
                cliente_data['rol'] = 'admin'
                print("Se forzó el rol a ADMIN en el login")
        
        cursor.close()
        conn.close()
        
        return jsonify({
            'mensaje': 'Login exitoso',
            'uid': uid,
            'cliente': cliente_data
        }), 200
        
    except Exception as e:
        print(f"Error en login: {e}")
        return jsonify({'error': str(e)}), 500

# ============================================
# 🔍 BUSCAR CLIENTE
# ============================================
@auth_bp.route('/api/buscar-cliente', methods=['GET'])
def buscar_cliente():
    query = request.args.get('q', '').lower()
    if len(query) < 2:
        return jsonify({"clientes": []})
    
    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)
    
    cursor.execute("""
        SELECT uid, nombre, email, telefono, codigo_cliente, rol 
        FROM clientes 
        WHERE LOWER(nombre) LIKE %s 
           OR LOWER(codigo_cliente) LIKE %s 
           OR telefono LIKE %s
        LIMIT 10
    """, (f'%{query}%', f'%{query}%', f'%{query}%'))
    
    resultados = cursor.fetchall()
    cursor.close()
    conn.close()
    
    return jsonify({"clientes": resultados})

# ============================================
# 🆕 OBTENER ROL
# ============================================
@auth_bp.route('/api/usuario/<uid>/rol', methods=['GET'])
def obtener_rol(uid):
    conn = get_db_connection()
    cursor = conn.cursor(dictionary=True)
    
    cursor.execute("SELECT rol FROM clientes WHERE uid = %s", (uid,))
    resultado = cursor.fetchone()
    cursor.close()
    conn.close()
    
    if not resultado:
        return jsonify({'error': 'No encontrado'}), 404
    
    return jsonify({'uid': uid, 'rol': resultado['rol']})

# ============================================
# 🔑 OBTENER CÓDIGO DE CLIENTE
# ============================================
@auth_bp.route('/api/cliente/<uid>/codigo', methods=['GET'])
def obtener_codigo_cliente(uid):
    try:
        conn = get_db_connection()
        cursor = conn.cursor(dictionary=True)
        
        cursor.execute("SELECT codigo_cliente FROM clientes WHERE uid = %s", (uid,))
        resultado = cursor.fetchone()
        cursor.close()
        conn.close()
        
        if not resultado:
            return jsonify({"error": "Cliente no encontrado"}), 404
        
        return jsonify({
            'uid': uid,
            'codigo_cliente': resultado['codigo_cliente'] or 'PENDIENTE'
        }), 200
        
    except Exception as e:
        return jsonify({"error": str(e)}), 500

# ============================================
# 🔑 OLVIDO DE CONTRASEÑA (PERSONALIZADO)
# ============================================
@auth_bp.route('/api/auth/olvido-password', methods=['POST'])
def api_olvido_password():
    try:
        datos = request.json
        email_destino = datos.get('email')

        if not email_destino:
            return jsonify({'error': 'Falta el correo'}), 400

        if not REMITENTE_PASSWORD:
            print("️ ERROR: EMAIL_PASSWORD no configurado en variables de entorno")
            return jsonify({'error': 'Configuración de correo no disponible'}), 500

        # Verificar si el usuario existe en MySQL
        conn = get_db_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT uid FROM clientes WHERE email = %s", (email_destino,))
        existe = cursor.fetchone()
        cursor.close()
        conn.close()
        
        if not existe:
            return jsonify({'error': 'No se pudo generar el enlace. Verifica el correo.'}), 404

        # Generar link de recuperación (esto aún depende de Firebase Auth)
        # Por ahora, redirigimos a Firebase
        from firebase_admin import auth as firebase_auth
        link_recuperacion = firebase_auth.generate_password_reset_link(email_destino)

        mensaje_html = f"""
        <html>
            <body style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #0b0f19; color: #ffffff; padding: 40px; text-align: center;">
                <div style="max-width: 500px; margin: auto; background-color: #161b22; padding: 30px; border-radius: 15px; border: 1px solid #D4AF37; box-shadow: 0 10px 20px rgba(0,0,0,0.5);">
                    <h1 style="color: #D4AF37; margin-bottom: 10px; font-size: 28px;">📦 iGrafic360</h1>
                    <p style="color: #a0aec0; font-size: 16px; margin-bottom: 30px;">Sistema de Tracking | Laboratorio</p>
                    
                    <div style="background-color: #0b0f19; padding: 20px; border-radius: 10px; border-left: 4px solid #D4AF37; margin-bottom: 30px; text-align: left;">
                        <h2 style="color: #ffffff; font-size: 18px; margin-top: 0;">¿Olvidaste tu contraseña?</h2>
                        <p style="color: #cbd5e0; font-size: 14px; line-height: 1.5;">Recibimos una solicitud para restablecer la contraseña de tu cuenta. Haz clic en el botón de abajo para continuar:</p>
                    </div>

                    <a href="{link_recuperacion}" 
                       style="display: inline-block; background-color: #D4AF37; color: #000000; padding: 15px 30px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 16px; transition: 0.3s;">
                       RESTABLECER CONTRASEÑA
                    </a>

                    <p style="color: #718096; font-size: 12px; margin-top: 40px;">
                        Si no solicitaste este cambio, puedes ignorar este correo de forma segura.<br>
                        Este enlace expirará pronto.
                    </p>
                    <hr style="border: 0; border-top: 1px solid #2d3748; margin: 20px 0;">
                    <p style="color: #D4AF37; font-size: 14px; font-weight: bold;">© 2026 iGrafic360 Global Logística</p>
                </div>
            </body>
        </html>
        """

        msg = MIMEText(mensaje_html, 'html')
        msg['Subject'] = 'Restablecer Contraseña - iGrafic360 🔐'
        msg['From'] = f"iGrafic360 <{REMITENTE_EMAIL}>"
        msg['To'] = email_destino

        server = smtplib.SMTP_SSL('smtp.gmail.com', 465)
        server.login(REMITENTE_EMAIL, REMITENTE_PASSWORD)
        server.sendmail(REMITENTE_EMAIL, email_destino, msg.as_string())
        server.quit()

        return jsonify({'success': True, 'mensaje': 'Correo de recuperación enviado'})

    except Exception as e:
        print(f"Error en olvido-password: {e}")
        return jsonify({'error': str(e)}), 500